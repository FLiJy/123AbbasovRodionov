<Window x:Class="_123AbbasovRodionov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4 - Abbasov Rodionov - Вариант 12" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Image Source="/Images/background (2).png" 
               Stretch="UniformToFill"
               Opacity="0.2"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Навигация (верхняя панель) -->
            <Border Grid.Row="0" Background="#2D2D2D" Padding="10">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">

                    <Button x:Name="BtnPage1" 
                            Content="📄 Страница 1" 
                            Click="NavButton_Click" 
                            Tag="Page1"
                            Width="150" Height="40"
                            Margin="10,0"
                            Background="Black"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="14"
                            ToolTip="Перейти к первой функции"
                            Cursor="Hand"/>

                    <Button x:Name="BtnPage2" 
                            Content="📄 Страница 2" 
                            Click="NavButton_Click" 
                            Tag="Page2"
                            Width="150" Height="40"
                            Margin="10,0"
                            Background="Black"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="14"
                            ToolTip="Перейти ко второй функции"
                            Cursor="Hand"/>

                    <Button x:Name="BtnPage3" 
                            Content="📄 Страница 3" 
                            Click="NavButton_Click" 
                            Tag="Page3"
                            Width="150" Height="40"
                            Margin="10,0"
                            Background="Black"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="14"
                            ToolTip="Перейти к третьей функции"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Фрейм для страниц -->
            <Frame x:Name="MainFrame" 
                   Grid.Row="1" 
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Grid>
    </Grid>
</Window>