<Page x:Class="_123AbbasovRodionov.Pages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 2 - Вариант 12 - Abbasov Rodionov">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Изображение функции -->
        <Image Grid.Row="0" Height="150" Stretch="Uniform"
               ToolTip="Формулы для выбора"
               Source="/Images/formula2.png"/>

        <!-- Ввод данных -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Label Content="x =" ToolTip="Введите значение x"/>
            <TextBox x:Name="TxtX" Width="100" 
                     ToolTip="Поле для ввода переменной x"/>
        </StackPanel>

        <!-- Выбор функции -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Label Content="Выберите функцию:" 
                   ToolTip="Выберите тип функции для вычисления"/>
            <RadioButton x:Name="RbSh" Content="sh(x)" GroupName="FuncSelect"
                         ToolTip="Гиперболический синус" Margin="5"/>
            <RadioButton x:Name="RbX2" Content="x²" GroupName="FuncSelect"
                         ToolTip="Квадрат числа" Margin="5"/>
            <RadioButton x:Name="RbExp" Content="e^x" GroupName="FuncSelect"
                         ToolTip="Экспонента" Margin="5"/>
        </StackPanel>

        <!-- Результат -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Label Content="Результат:" ToolTip="Результат вычисления"/>
            <TextBox x:Name="TxtResult" Width="200" 
                     IsReadOnly="True"
                     ToolTip="Поле для вывода результата"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="Вычислить" Click="Calculate_Click" 
                    ToolTip="Вычислить значение функции"/>
            <Button Content="Очистить" Click="Clear_Click" 
                    ToolTip="Очистить все поля"/>
        </StackPanel>

        <!-- Сообщение об ошибке -->
        <TextBlock Grid.Row="5" x:Name="TxtError" 
                   Foreground="Red" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Margin="10"/>
    </Grid>
</Page>