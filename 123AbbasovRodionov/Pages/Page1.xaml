<Page x:Class="_123AbbasovRodionov.Pages.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Страница 1 - Вариант 12 - Abbasov Rodionov">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Изображение функции -->
        <Image Grid.Row="0" Height="150" Stretch="Uniform"
               ToolTip="Формула для варианта 12"
               Source="/Images/formula1.png"/>

        <!-- Ввод данных -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Label Content="x =" ToolTip="Введите значение x"/>
            <TextBox x:Name="TxtX" Width="100" 
                     ToolTip="Поле для ввода переменной x"/>

            <Label Content="y =" ToolTip="Введите значение y"/>
            <TextBox x:Name="TxtY" Width="100" 
                     ToolTip="Поле для ввода переменной y"/>

            <Label Content="z =" ToolTip="Введите значение z"/>
            <TextBox x:Name="TxtZ" Width="100" 
                     ToolTip="Поле для ввода переменной z"/>
        </StackPanel>

        <!-- Результат -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Label Content="Результат:" ToolTip="Результат вычисления"/>
            <TextBox x:Name="TxtResult" Width="200" 
                     IsReadOnly="True"
                     ToolTip="Поле для вывода результата"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="Вычислить" Click="Calculate_Click" 
                    ToolTip="Вычислить значение функции"/>
            <Button Content="Очистить" Click="Clear_Click" 
                    ToolTip="Очистить все поля"/>
        </StackPanel>

        <!-- Сообщение об ошибке -->
        <TextBlock Grid.Row="4" x:Name="TxtError" 
                   Foreground="Red" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Margin="10"/>
    </Grid>
</Page>