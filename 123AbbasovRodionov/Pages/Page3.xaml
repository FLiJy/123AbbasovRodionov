<Page x:Class="_123AbbasovRodionov.Pages.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      Title="Страница 3 - Вариант 12 - Abbasov Rodionov">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Изображение функции -->
        <Image Grid.Row="0" Height="100" Stretch="Uniform"
               ToolTip="Формула для варианта 12"
               Source="/Images/formula3.png"/>

        <!-- Ввод данных -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Label Content="x₀ =" ToolTip="Начало отрезка"/>
            <TextBox x:Name="TxtX0" Width="80" ToolTip="Начальное значение x"/>

            <Label Content="xₖ =" ToolTip="Конец отрезка"/>
            <TextBox x:Name="TxtXk" Width="80" ToolTip="Конечное значение x"/>

            <Label Content="dx =" ToolTip="Шаг функции"/>
            <TextBox x:Name="TxtDx" Width="80" ToolTip="Шаг изменения x"/>

            <Label Content="a =" ToolTip="Параметр a"/>
            <TextBox x:Name="TxtA" Width="80" ToolTip="Значение параметра a"/>

            <Label Content="b =" ToolTip="Параметр b"/>
            <TextBox x:Name="TxtB" Width="80" ToolTip="Значение параметра b"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="Вычислить" Click="Calculate_Click" 
                    ToolTip="Вычислить значения функции"/>
            <Button Content="Очистить" Click="Clear_Click" 
                    ToolTip="Очистить все поля"/>
        </StackPanel>

        <!-- Результаты и график -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Таблица результатов -->
            <TextBox Grid.Column="0" x:Name="TxtResults" 
                     IsReadOnly="True" TextWrapping="Wrap"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     Margin="5" ToolTip="Таблица результатов вычислений"/>

            <!-- График -->
            <lvc:CartesianChart Grid.Column="1" x:Name="Chart" 
                                Margin="5" ToolTip="График функции">
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Title="X" LabelFormatter="{Binding XFormatter}"/>
                </lvc:CartesianChart.AxisX>
                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Title="Y" LabelFormatter="{Binding YFormatter}"/>
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>
        </Grid>

        <!-- Сообщение об ошибке -->
        <TextBlock Grid.Row="4" x:Name="TxtError" 
                   Foreground="Red" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Margin="10"/>
    </Grid>
</Page>